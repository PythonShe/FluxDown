---
import Layout from "../layouts/Layout.astro";
import { FloatingNavbar } from "../components/ui/floating-navbar";
import AnnouncementBar from "../components/AnnouncementBar";
import LogoVotePage from "../components/LogoVotePage";
import Footer from "../components/Footer";
import CommunityFloat from "../components/CommunityFloat";
---

<Layout title="Logo Vote - FluxDown" description="Vote for your favorite FluxDown logo design or submit your own. The community decides the future look of FluxDown!">
  <AnnouncementBar client:load />
  <FloatingNavbar client:load />
  <main class="relative">
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute top-0 left-1/3 w-[500px] h-[300px] bg-brand-sky/[0.03] blur-[120px] rounded-full"></div>
      <div class="absolute bottom-0 right-1/4 w-[400px] h-[300px] bg-brand-cyan/[0.03] blur-[100px] rounded-full"></div>
    </div>
    <LogoVotePage client:load />
  </main>
  <Footer client:load />
  <CommunityFloat client:load />
</Layout>
